@echo off
echo Исправление бага и подготовка к публикации...
echo.

REM Добавляем все изменения
git add .
echo [1/3] Изменения добавлены.

REM Создаем коммит с описанием
git commit -m "Fix: исправлена статистика молний и обновлены функции"
echo [2/3] Коммит создан.

REM Проверяем наличие удаленного репозитория
git remote get-url origin >nul 2>&1
if errorlevel 1 (
    echo Удаленный репозиторий не настроен. Добавляем...
    git remote add origin https://github.com/HouseGram-code/HouseGram-Web.git
) else (
    echo Удаленный репозиторий уже настроен.
)

REM Отправляем изменения
echo [3/3] Отправка на GitHub...
git push origin main

echo.
if errorlevel 1 (
    echo ==========================================
    echo ОШИБКА ПРИ ОТПРАВКЕ!
    echo ==========================================
    echo Возможно, требуется ввод логина и токена.
    echo Если запросило пароль - вставьте ваш токен github_pat_...
    echo (символы не будут видны при вводе - это нормально)
    echo ==========================================
    pause
) else (
    echo ==========================================
    echo УСПЕШНО! Код опубликован на GitHub.
    echo ==========================================
    pause
)
