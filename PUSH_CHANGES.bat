@echo off
echo ========================================
echo Отправка изменений на GitHub
echo ========================================

echo.
echo Шаг 1: Добавление всех файлов...
git add .

echo.
echo Шаг 2: Создание коммита...
set /p message="Введите описание изменений: "
git commit -m "%message%"

echo.
echo Шаг 3: Отправка на GitHub...
git push origin main

echo.
echo ========================================
echo Готово! Изменения отправлены на GitHub
echo ========================================
pause
