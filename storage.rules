rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /stickers/{userId}/{stickerId} {
      // Authenticated users can upload stickers to their own folder
      allow write: if request.auth != null && request.auth.uid == userId;
      // Anyone can read stickers
      allow read: if true;
    }
    
    match /avatars/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if true;
    }
    
    match /voice-messages/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null;
    }
    
    match /files/{userId}/{allPaths=**} {
      allow write: if request.auth != null && request.auth.uid == userId;
      allow read: if request.auth != null;
    }
  }
}
